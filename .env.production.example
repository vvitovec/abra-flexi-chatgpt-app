# Production ChatGPT App runtime
APP_NAME=ABRA Flexi ChatGPT App
APP_BASE_URL=https://flexi.your-domain.example
APP_DOMAIN=https://flexi.your-domain.example
WIDGET_RESOURCE_DOMAIN=https://flexi.your-domain.example
APP_PORT=8787
APP_DATA_DIR=/var/lib/flexi-chatgpt-app
