{
  "defaultProfile": "prod",
  "logDirectory": ".flexi-harness/logs",
  "confirmationTtlSeconds": 300,
  "profiles": {
    "test": {
      "baseUrl": "https://demo.flexibee.eu",
      "company": "demo",
      "mode": "test",
      "writes": "confirm",
      "defaultFormat": "json",
      "usernameEnv": "FLEXI_TEST_USERNAME",
      "passwordEnv": "FLEXI_TEST_PASSWORD",
      "allowWriteOverrideWithoutValidation": false
    },
